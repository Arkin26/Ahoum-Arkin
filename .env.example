# Local development
SECRET_KEY=your-secret-key-here
DEBUG=True
DATABASE_URL=postgres://postgres:postgres@db:5432/ahoum
REDIS_URL=redis://redis:6379/0
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Vercel production (set these in the Vercel dashboard) ---
